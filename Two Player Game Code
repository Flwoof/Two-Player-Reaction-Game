void loop() {
  while(resetMode){
    resetScreen();
    counter = 0;
    counter2 = 0;
    if(digitalRead(touch1) == HIGH || digitalRead(touch2) == HIGH || digitalRead(redB) == HIGH 
    || digitalRead(redB2) == HIGH || digitalRead(greenB) == HIGH || digitalRead(greenB2) == HIGH
    || digitalRead(yellowB) == HIGH || digitalRead(yellowB2) == HIGH || digitalRead(blueB) == HIGH
    || digitalRead(blueB2) == HIGH ){
      readyStage = true;
      resetMode = false;
    }
  }
  while(readyStage && counter2 != 10 && counter != 10){
    if(counter == 10 || counter2 == 10){
      return;
    }
    if(digitalRead(touch1) == HIGH){
      ready1 = " Ready!";
      if(p1Beep == 0){
        tone(buzzer, 780, 80); // beep 1
        delay(120);
        tone(buzzer, 880, 100); // beep 2
        p1Beep = 1;
      }
    }
    else{
      ready1 = "";
      p1Beep = 0;
    }
    if(digitalRead(touch2) == HIGH){
      ready2 = " Ready!";
      if(p2Beep == 0){
        tone(buzzer, 780, 80); // beep 1
        delay(120);
        tone(buzzer, 880, 100); // beep 2
        p2Beep = 1;
      }
    }
    else{
      ready2 = "";
      p2Beep = 0;
    }
    if(ready1 == " Ready!" && ready2 == " Ready!" )
    {
      readyDisplay();
      delay(500);
      countdown();
    }
    readyDisplay();
  }
  while(pickPeriod && counter2 != 10 && counter != 10){
    updateDisplay();
    currentMillis = millis();              
    period = random(1000, 10000);
    Serial.print(period);
    Serial.println(" milliseconds");
    pickLight = true;
    startMillis = currentMillis;         
    pickPeriod = false;
  }

  while(pickLight && counter2 != 10 && counter != 10){
    if(digitalRead(touch2) == LOW){
      delay(200);
      counter++;
      falseStartP2();
      if(counter == 10){
        player1Win();
        return;
      }
      else{
        readyStage = true;
        pickLight = false;
        break;
      }
  }
  if(digitalRead(touch1) == LOW){
      delay(200);
      counter2++;
      falseStartP1();
      if(counter2 == 10){
        player2Win();
        return;
      }
      else{
        readyStage = true;
        pickLight = false;
        break;
      }
